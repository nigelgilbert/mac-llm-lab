# Local environment files (may contain secrets)
host/.env
client/.env
**/.env
!**/.env.example

# macOS
.DS_Store

# Editors
.vscode/
.idea/
*.swp

# Claude Code local state
.claude/

# Python (Phase 3+ sidecar-loader)
__pycache__/
*.py[cod]
.venv/
venv/

# Logs
*.log

# Per-cycle sweep stdout dumps from run-overnight-screen.sh.
# These are raw `docker compose run ... | tee` traces. Keep pre-existing
# sprint-baseline reports (T32-TUNING-PROGRESS.md, TIER-EVAL-V2-SPRINT-1-
# BASELINE.md) which sit beside this pattern.
host/test/logs/OVERNIGHT-SCREEN-explore-*.md

# Per-cycle explore artifacts (summary.md + snapshots/) auto-generated by
# scripts/explore-summarize.mjs from the run_registry.<sweep>.jsonl. The
# conclusions land in host/test/docs/difficulty-pack/1.21-cycle-N-
# recommendations.md memos; the artifacts themselves are regenerable from
# the registry JSONL and shouldn't be committed.
host/test/docs/difficulty-pack/explore/
