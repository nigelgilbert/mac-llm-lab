<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mac-llm-lab.opencode-server</string>

    <!--
      SECOND, OpenCode-dedicated llama-server (Config B, issue #005).

      This is the LOGIN-PERSISTENT option only. The canonical, phase-swap-friendly
      interface is the direct-boot control script:
          ./host/llama-server/scripts/opencode-server {start|stop|status|health|probe}
      Render + bootstrap this plist with:
          ./host/llama-server/scripts/opencode-server install   (sed-fills placeholders)
      Do NOT install by hand — placeholders are filled from models.conf tier-64.

      Distinct from the production claw plist (com.mac-llm-lab.llama-server):
        - own Label + own port (:11436, vs claw :11435, LiteLLM :4000)
        - --jinja + the corrected template (#004), NO claw.gbnf grammar
        - thinking-off via --chat-template-kwargs '{"enable_thinking":false}'
        - generous -n so tool-call args don't truncate
        - own log path, so it never clobbers claw's /tmp/llama-server.log
      Because the Label differs, bootstrapping/booting-out this agent NEVER
      disturbs the claw launchd instance.

      Placeholders (filled by `opencode-server install`):
        __BINARY__ __GGUF_PATH__ __TEMPLATE_PATH__ __CTX_SIZE__ __BATCH_SIZE__
        __NPREDICT__ __TEMP__ __TOP_P__ __TOP_K__ __REPEAT_PENALTY__ __PRESENCE_PENALTY__
    -->

    <key>ProgramArguments</key>
    <array>
        <string>__BINARY__</string>

        <!-- network — own port; 0.0.0.0 so docker reaches via host.docker.internal -->
        <string>--host</string>
        <string>0.0.0.0</string>
        <string>--port</string>
        <string>11436</string>

        <!-- model — same tier-64 GGUF as claw -->
        <string>--model</string>
        <string>__GGUF_PATH__</string>
        <string>--alias</string>
        <string>opencode</string>

        <!-- context + memory — mirrors the claw plist -->
        <string>--ctx-size</string>
        <string>__CTX_SIZE__</string>
        <string>-ngl</string>
        <string>999</string>
        <string>-fa</string>
        <string>on</string>
        <string>--cache-type-k</string>
        <string>q8_0</string>
        <string>--cache-type-v</string>
        <string>q8_0</string>
        <string>--batch-size</string>
        <string>__BATCH_SIZE__</string>

        <!-- sampler — tier-64 values from models.conf (same as claw) -->
        <string>--temp</string>
        <string>__TEMP__</string>
        <string>--top-p</string>
        <string>__TOP_P__</string>
        <string>--top-k</string>
        <string>__TOP_K__</string>
        <string>--repeat-penalty</string>
        <string>__REPEAT_PENALTY__</string>
        <string>--presence-penalty</string>
        <string>__PRESENCE_PENALTY__</string>
        <string>--repeat-last-n</string>
        <string>256</string>

        <!-- Config B serving — corrected template + native <tool_call>, NO grammar.
             Deliberately omits claw's --grammar-file. -->
        <string>--jinja</string>
        <string>--chat-template-file</string>
        <string>__TEMPLATE_PATH__</string>

        <!-- thinking-off. --chat-template-kwargs is deprecated-but-functional on
             build 5594d13 (warning only); kept for parity with the setup-guide
             recipe. --reasoning off is the startup-only alternative. -->
        <string>--chat-template-kwargs</string>
        <string>{"enable_thinking":false}</string>

        <!-- generous n-predict: avoid tool-call arg truncation -->
        <string>-n</string>
        <string>__NPREDICT__</string>

        <!-- misc -->
        <string>--metrics</string>
    </array>

    <!-- Auto-start at login and revive on crash. -->
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <!-- Own log path — never clobbers claw's /tmp/llama-server.log. -->
    <key>StandardOutPath</key>
    <string>/tmp/opencode-llama-server.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/opencode-llama-server.log</string>

    <!-- Crash backoff, in case the binary dies on bad config. -->
    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>
