{
  "name": "host-test (Node 24)",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/test",
  "workspaceMount": "source=${localWorkspaceFolder},target=/test,type=bind,consistency=cached",
  "overrideCommand": true,
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "typescript.tsserver.experimental.enableProjectDiagnostics": false
      }
    }
  }
}
