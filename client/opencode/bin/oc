#!/usr/bin/env bash
# ============================================================================
# oc — one command from any repo to the containerized OpenCode agent (#003)
#
# Makes the container invisible (migration decision §2.10): asserts the
# tier's llama-server is green (booting it if not), mounts $PWD at
# /workspace, mounts the tier-matched opencode.json AND the global prompt
# (AGENTS.md) into the container, then drops into the OpenCode TUI — or runs
# a headless one-shot.
#
# Usage:
#   oc                       interactive TUI on $PWD (default tier 64)
#   oc run "<prompt>" [...]  headless one-shot ($* passed to `opencode run`
#                            after a `--` separator: every arg is prompt text,
#                            dash-leading prompts can't parse as flags)
#   oc probe                 injection wire-capture oracle (#001): proves the
#                            global AGENTS.md actually lands in the agent
#                            system prompt, via an in-container mock endpoint
#                            (deterministic; needs no llama-server)
#   oc status                tier server health + resolved prompt/config
#   oc help | -h | --help
#
# Flags (before the subcommand):
#   -t|--tier 16|32|64       memory tier (default: $OPENCODE_TIER, else 64)
#   --ports                  publish the compose service ports (dev server
#                            8080). OFF by default: the claw container still
#                            holds :8080 until the #008 gut.
#
# Environment:
#   OPENCODE_TIER            same as -t (flag wins)
#   OC_PROMPT_FILE           host path of the global prompt source. Default
#                            resolution: ~/.config/opencode/AGENTS.md (the
#                            wizard-installed location, decision §2.6) if it
#                            exists, else the repo source
#                            host/llama-server/docs/system-prompt.md.
#   OPENCODE_CONFIG_JSON     escape hatch: override the tier-matched
#                            opencode.json mounted into the container
#                            (absolute path; used by probes/sweeps)
#   OC_SERVER_HOST           where the tier llama-server lives (default
#                            127.0.0.1). Set to the serving Mac's LAN address
#                            in the wizard's client-only topology (#007),
#                            paired with OPENCODE_CONFIG_JSON pointing at a
#                            rendered opencode.remote*.json. oc cannot
#                            boot/stop a remote server: red remote = exit 3.
#   OC_KEEP_SERVER=1         leave an on-demand (tier 16/32) server running
#                            after the session instead of stopping it
#   OC_ALLOW_BROAD_WORKSPACE=1
#                            override the workspace-root guard (#027): by
#                            default oc REFUSES to mount $HOME, /, or any
#                            filesystem root rw into the agent container
#                            (container-first is only as strong as the mount).
#                            Set this for the rare deliberate case.
#
# Exit codes:
#   0   success (or `opencode`'s own exit code passed through)
#   1   usage error / no TTY for the TUI
#   2   PROMPT-INJECTION PRECONDITION FAILED (missing/unreadable/empty prompt
#       file, missing tier config) — injection failure is SILENT in OpenCode
#       (#001), so the wrapper owns this assertion and fails loud
#   3   tier server could not be made green
#
# Tier serving model (decision §2.5; ports/labels/configs all come from the
# single tier table host/llama-server/tiers.conf, #016):
#   64  RESIDENT — launchd daemon (table label/port). If red and the launchd
#       job is loaded, we WAIT for green (model load takes ~minutes; never
#       bootout a loading/healthy service). If red and not loaded,
#       `opencode-server install` bootstraps it.
#   16  ON-DEMAND — direct-boot `opencode-server start`; STOPPED on exit iff
#       oc started it (OC_KEEP_SERVER=1 to keep). A tier-16 server that was
#       already green is left untouched.
#   32  ON-DEMAND — same as 16 (no launchd plist by design; table label "-").
#
# Container-first is architectural (decision §2.4): oc never runs the
# opencode binary on the host; everything goes through `docker compose run`
# in client/opencode, which sandboxes the agent to the mounted workspace.
# ============================================================================
set -euo pipefail

# Self-locate THROUGH symlinks: the wizard (#007) installs ~/.local/bin/oc as
# a symlink here, and a bare dirname of BASH_SOURCE would resolve to the
# symlink's dir (~/.local/bin) and break every COMPOSE_DIR/REPO_ROOT path.
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_SOURCE" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
  SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
  [[ "$SCRIPT_SOURCE" != /* ]] && SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
COMPOSE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"              # client/opencode
REPO_ROOT="$(cd "$COMPOSE_DIR/../.." && pwd)"            # mac-llm-lab-1
SERVER_SCRIPT="$REPO_ROOT/host/llama-server/scripts/opencode-server"
INVOKE_PWD="$PWD"                                        # the workspace to mount

# Single tier-identity table (#016): port / config json / launchd label / log
# path are resolved from host/llama-server/tiers.conf — the same file the
# launcher, sweep driver and wizard resolve. No private case map in oc.
TIERS_CONF="$REPO_ROOT/host/llama-server/tiers.conf"
if [[ ! -f "$TIERS_CONF" ]]; then
  echo "oc: ERROR: tier table missing: $TIERS_CONF" >&2; exit 1
fi
# shellcheck source=../../../host/llama-server/tiers.conf
source "$TIERS_CONF"

REPO_PROMPT_SOURCE="$REPO_ROOT/host/llama-server/docs/system-prompt.md"
WIZARD_PROMPT="$HOME/.config/opencode/AGENTS.md"
CONTAINER_PROMPT_PATH="/root/.config/opencode/AGENTS.md" # the #001 winner

die()  { echo "oc: ERROR: $*" >&2; exit 1; }
die2() { echo "oc: PROMPT PRECONDITION FAILED: $*" >&2; exit 2; }
die3() { echo "oc: SERVER ERROR: $*" >&2; exit 3; }

usage() { sed -n '/^# Usage:/,/^# ===/p' "${BASH_SOURCE[0]}" | sed '$d; s/^# \{0,1\}//'; }

# --- arg parsing ------------------------------------------------------------
TIER="${OPENCODE_TIER:-$TIER_DEFAULT}"
PUBLISH_PORTS=0
SUBCMD=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -t|--tier) [[ $# -ge 2 ]] || die "$1 needs a value (16|32|64)"; TIER="$2"; shift 2 ;;
    --ports)   PUBLISH_PORTS=1; shift ;;
    -h|--help|help) usage; exit 0 ;;
    run|probe|status) SUBCMD="$1"; shift; break ;;
    -*) die "unknown flag: $1 (see oc --help)" ;;
    *)  die "unknown subcommand: $1 (see oc --help)" ;;
  esac
done

# #016: resolve the tier row from the table (sets TIER_PORT /
# TIER_OPENCODE_CONFIG / TIER_LAUNCHD_LABEL / TIER_LOG_PATH / ...).
tier_resolve "$TIER" || die "unsupported tier: $TIER (known tiers: $TIERS_ALL — see host/llama-server/tiers.conf)"
PORT="$TIER_PORT"
TIER_CONFIG="$COMPOSE_DIR/$TIER_OPENCODE_CONFIG"

# --- prompt-injection preconditions (FAIL LOUD — injection is silent) -------
resolve_prompt() {
  if [[ -n "${OC_PROMPT_FILE:-}" ]]; then
    PROMPT_FILE="$OC_PROMPT_FILE"; PROMPT_ORIGIN="OC_PROMPT_FILE"
  elif [[ -e "$WIZARD_PROMPT" ]]; then
    PROMPT_FILE="$WIZARD_PROMPT"; PROMPT_ORIGIN="wizard install (~/.config/opencode/AGENTS.md)"
  else
    PROMPT_FILE="$REPO_PROMPT_SOURCE"; PROMPT_ORIGIN="repo source (host/llama-server/docs/system-prompt.md)"
  fi
}

assert_prompt() {
  resolve_prompt
  [[ -e "$PROMPT_FILE" ]] || die2 "global prompt source not found: $PROMPT_FILE
  The agent would run WITHOUT its system prompt and OpenCode would not tell you.
  Fix: restore the file, run the wizard prompt-install step (#007), or point
  OC_PROMPT_FILE at a readable prompt markdown file."
  [[ -f "$PROMPT_FILE" ]] || die2 "global prompt source is not a regular file: $PROMPT_FILE
  (a directory would bind-mount over $CONTAINER_PROMPT_PATH and inject nothing)"
  [[ -r "$PROMPT_FILE" ]] || die2 "global prompt source not readable: $PROMPT_FILE"
  [[ -s "$PROMPT_FILE" ]] || die2 "global prompt source is EMPTY (0 bytes): $PROMPT_FILE
  An empty AGENTS.md mounts cleanly and silently injects nothing."
  # absolute path for the docker -v mount
  PROMPT_FILE="$(cd "$(dirname "$PROMPT_FILE")" && pwd)/$(basename "$PROMPT_FILE")"
}

assert_config() {
  # If the caller pre-set OPENCODE_CONFIG_JSON we honor it (probe/sweep escape
  # hatch) but still refuse to mount a missing file: compose would otherwise
  # fall back to ./opencode.json and silently dial the WRONG TIER's port — the
  # #019 sweep-bug class.
  CONFIG_JSON="${OPENCODE_CONFIG_JSON:-$TIER_CONFIG}"
  [[ -f "$CONFIG_JSON" && -r "$CONFIG_JSON" ]] || die2 "opencode config missing/unreadable: $CONFIG_JSON
  Without it the container would fall back to the default tier-64 config and
  silently dial the wrong server port."
  # absolute path for the compose bind mount (#014): compose resolves a
  # relative source against --project-directory (client/opencode), NOT the
  # caller's cwd — so a relative override would pass the check above yet
  # bind-mount a nonexistent path that docker auto-creates as an empty
  # DIRECTORY over /root/.config/opencode/opencode.json (the same trap
  # assert_prompt already closes for PROMPT_FILE).
  CONFIG_JSON="$(cd "$(dirname "$CONFIG_JSON")" && pwd)/$(basename "$CONFIG_JSON")"
}

# --- tier server lifecycle ---------------------------------------------------
# OC_SERVER_HOST (#007 client-only): non-local servers are health-checked but
# never lifecycled — oc can't launchctl/start a daemon on another Mac.
SERVER_HOST="${OC_SERVER_HOST:-127.0.0.1}"
green() { [[ "$(curl -s -o /dev/null -w '%{http_code}' "http://$SERVER_HOST:$PORT/health" 2>/dev/null)" == "200" ]]; }

# Resident-daemon launchd check — label from the tier table (#016); "-" means
# the tier has no launchd path by design, so it can never read as loaded.
launchd_loaded_64() {
  [[ "$TIER_LAUNCHD_LABEL" != "-" ]] || return 1
  launchctl print "gui/$(id -u)/$TIER_LAUNCHD_LABEL" >/dev/null 2>&1
}

wait_green() { # $1 = seconds
  local t="$1"
  while (( t > 0 )); do green && return 0; sleep 2; t=$((t-2)); done
  return 1
}

STARTED_ON_DEMAND=0
stop_on_demand() {
  if [[ "$STARTED_ON_DEMAND" == 1 && "${OC_KEEP_SERVER:-0}" != 1 ]]; then
    echo "oc: stopping on-demand tier-$TIER server (:$PORT)" >&2
    OPENCODE_TIER="$TIER" "$SERVER_SCRIPT" stop >/dev/null 2>&1 || true
  fi
}

# True for loopback spellings of OC_SERVER_HOST — the only hosts where a
# config dialing host.docker.internal still reaches the same machine.
server_host_is_local() {
  case "$SERVER_HOST" in
    127.*|localhost|::1) return 0 ;;
    *) return 1 ;;
  esac
}

assert_server() {
  if [[ "$SERVER_HOST" != "127.0.0.1" ]]; then
    # Remote pairing check (#027): the health check below greens against the
    # REMOTE, but the container dials whatever baseURL is in the mounted
    # config. With a stock config that's host.docker.internal — i.e. the
    # local Mac — so a green check would mask the agent talking to the wrong
    # (possibly dead) server. The pairing requirement used to live only in
    # the header comment; now it's enforced. Runs BEFORE the health probe so
    # an unreachable OC_SERVER_HOST can't stall the failure.
    if ! server_host_is_local && grep -q 'host\.docker\.internal' "$CONFIG_JSON"; then
      die3 "OC_SERVER_HOST=$SERVER_HOST is remote, but the resolved config still dials host.docker.internal (the LOCAL Mac):
  config: $CONFIG_JSON
  The health check would green against the remote while the agent container
  talks to the local host. Pair OC_SERVER_HOST with OPENCODE_CONFIG_JSON
  pointing at a rendered remote config (opencode.remote*.json) whose baseURL
  names the serving Mac."
    fi
    green || die3 "remote server not green at http://$SERVER_HOST:$PORT/health
  oc cannot boot/lifecycle a remote server (OC_SERVER_HOST=$SERVER_HOST) —
  bring the tier daemon up on the serving Mac, then retry."
    return 0
  fi
  [[ -x "$SERVER_SCRIPT" ]] || die3 "opencode-server script missing: $SERVER_SCRIPT"
  if green; then return 0; fi
  if [[ "$TIER" == 64 ]]; then
    if launchd_loaded_64; then
      # Loaded but red: it is (re)loading the 21 GB model. NEVER bootout a
      # live service here — just wait for green.
      echo "oc: resident tier-64 daemon is loaded but not green yet — waiting (model load)" >&2
      wait_green 240 || die3 "resident tier-64 daemon did not reach green /health on :$PORT within 240s
  Inspect: $SERVER_SCRIPT status   and $TIER_LOG_PATH"
    else
      echo "oc: resident tier-64 daemon not installed — bootstrapping launchd service" >&2
      OPENCODE_TIER=64 "$SERVER_SCRIPT" install >&2 || die3 "opencode-server install failed for tier-64"
    fi
  else
    echo "oc: booting on-demand tier-$TIER server on :$PORT (stopped again on exit; OC_KEEP_SERVER=1 to keep)" >&2
    OPENCODE_TIER="$TIER" "$SERVER_SCRIPT" start >&2 || die3 "opencode-server start failed for tier-$TIER"
    STARTED_ON_DEMAND=1
    trap stop_on_demand EXIT
  fi
  green || die3 "tier-$TIER server still not green on :$PORT"
}

# --- container invocation -----------------------------------------------------
# Everything runs through docker compose in client/opencode: same image, same
# mounts/extra_hosts (models.dev black-hole, host-gateway) as the harness.
compose() {
  docker compose -f "$COMPOSE_DIR/docker-compose.yml" --project-directory "$COMPOSE_DIR" "$@"
}

run_container() { # $@ = command inside the container; needs WORKSPACE + CONFIG_JSON + PROMPT_FILE set
  local -a flags=(--rm -v "$PROMPT_FILE:$CONTAINER_PROMPT_PATH:ro")
  [[ "$PUBLISH_PORTS" == 1 ]] && flags+=(--service-ports)
  # No TTY (CI, pipes, probe): tell compose not to allocate one.
  [[ -t 0 && -t 1 ]] || flags+=(-T)
  WORKSPACE="$INVOKE_PWD" OPENCODE_CONFIG_JSON="$CONFIG_JSON" \
    compose run "${flags[@]}" opencode "$@"
}

# Workspace-root guard (#027): oc mounts the workspace rw into the agent
# container, so a habitual `oc` typed in $HOME would hand a weak-tier model rw
# access to SSH keys, wizard state, everything — and `oc` in / hands it the
# whole disk. Refuse $HOME, /, and any filesystem root (mount point: device
# number differs from its parent's — catches /Volumes/X, /System/Volumes/Data,
# network mounts). OC_ALLOW_BROAD_WORKSPACE=1 overrides for the rare
# deliberate case. Everything else keeps note_workspace's non-git warning.
assert_workspace() {
  local ws home_resolved reason=""
  # Physical resolution: a symlink into $HOME must not dodge the guard.
  ws="$(cd -P "$INVOKE_PWD" && pwd)"
  home_resolved="$(cd -P "$HOME" && pwd)"
  if [[ "$ws" == "/" ]]; then
    reason="the filesystem root (/)"
  elif [[ "$ws" == "$home_resolved" ]]; then
    reason="your home directory (\$HOME)"
  elif [[ "$(stat -f %d "$ws" 2>/dev/null || stat -c %d "$ws" 2>/dev/null)" \
       != "$(stat -f %d "$ws/.." 2>/dev/null || stat -c %d "$ws/.." 2>/dev/null)" ]]; then
    reason="a filesystem root (mount point)"
  fi
  [[ -z "$reason" ]] && return 0
  if [[ "${OC_ALLOW_BROAD_WORKSPACE:-0}" == 1 ]]; then
    echo "oc: WARNING: mounting $ws rw into the agent container ($reason) — OC_ALLOW_BROAD_WORKSPACE=1 override active" >&2
    return 0
  fi
  die "refusing to mount $ws as the agent workspace: it is $reason.
  The agent container gets read-write access to everything under the
  workspace mount. cd into a project directory first, or set
  OC_ALLOW_BROAD_WORKSPACE=1 if you really mean it."
}

note_workspace() {
  if ! git -C "$INVOKE_PWD" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    # Not fatal: global AGENTS.md injects in bare dirs too (#001 bonus finding).
    echo "oc: note: $INVOKE_PWD is not a git repo (prompt still injects; OpenCode snapshots/undo want git)" >&2
  fi
}

# --- subcommands ---------------------------------------------------------------
cmd_status() {
  resolve_prompt
  echo "tier        : $TIER (port :$PORT)"
  echo "config      : ${OPENCODE_CONFIG_JSON:-$TIER_CONFIG}"
  echo "prompt      : $PROMPT_FILE  [$PROMPT_ORIGIN]"
  if [[ -s "$PROMPT_FILE" && -r "$PROMPT_FILE" && -f "$PROMPT_FILE" ]]; then
    echo "prompt check: OK ($(wc -c < "$PROMPT_FILE" | tr -d ' ') bytes)"
  else
    echo "prompt check: FAIL (missing/unreadable/empty — oc run would exit 2)"
  fi
  if green; then echo "server      : green (http://$SERVER_HOST:$PORT/health)"
  elif [[ "$SERVER_HOST" != "127.0.0.1" ]]; then
    echo "server      : not green at $SERVER_HOST:$PORT (remote — oc will NOT boot it; exit 3)"
  else echo "server      : not green (oc would boot it: tier 64 → launchd, 16/32 → on-demand)"; fi
}

# Injection wire-capture oracle (#001's deterministic replacement for the
# flaky behavioral PROOF check, content-true since #014): point OpenCode at an
# in-container localhost mock that records the /v1/chat/completions request
# body, mount a probe copy of the resolved global prompt with a unique
# SENTINEL line appended at the END, run a trivial prompt THROUGH THE NORMAL
# oc CONTAINER PATH (same mount target, same compose service), then require
# the sentinel in the captured body. Sentinel-at-the-tail is the oracle:
# it proves the prompt content itself (through its last line) reached the
# model request — a truncated injection fails, and an upstream rewording of
# the "Instructions from:" attribution line cannot false-fail the probe (the
# attribution grep is kept as a secondary diagnostic only).
cmd_probe() {
  assert_prompt
  local ws cfg
  ws="$(mktemp -d /tmp/oc-probe.XXXXXX)"
  cfg="$ws/opencode.probe.json"
  cat > "$cfg" <<'EOF'
{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama-local": {
      "name": "oc probe capture mock",
      "npm": "@ai-sdk/openai-compatible",
      "options": { "baseURL": "http://127.0.0.1:9099/v1", "apiKey": "sk-local-no-auth" },
      "models": { "opencode": { "name": "oc probe capture mock" } }
    }
  },
  "model": "llama-local/opencode"
}
EOF
  cat > "$ws/_mock.js" <<'EOF'
// Minimal OpenAI-compatible capture endpoint (in-container 127.0.0.1 —
// sidesteps the macOS-firewall problem that kills host-side mocks, see #001).
// argv[2] = optional listen delay in ms (test knob, see OC_PROBE_MOCK_DELAY_MS
// in cmd_probe — simulates slow node startup to exercise the readiness poll).
const http = require('http'), fs = require('fs');
const delayMs = Number(process.argv[2] || 0);
const server = http.createServer((req, res) => {
  if (req.url === '/health') {
    // Readiness-poll target (#027): answered without touching the capture
    // file, so polling can never make _capture.jsonl spuriously non-empty.
    res.writeHead(200); res.end('ok'); return;
  }
  let body = '';
  req.on('data', c => body += c);
  req.on('end', () => {
    fs.appendFileSync('/workspace/_capture.jsonl', JSON.stringify({url: req.url, body}) + '\n');
    res.writeHead(200, {'content-type': 'application/json'});
    res.end(JSON.stringify({id: 'mock', object: 'chat.completion', created: 0, model: 'opencode',
      choices: [{index: 0, message: {role: 'assistant', content: 'ok'}, finish_reason: 'stop'}],
      usage: {prompt_tokens: 1, completion_tokens: 1, total_tokens: 2}}));
  });
});
setTimeout(() => server.listen(9099, '127.0.0.1'), delayMs);
EOF
  # Probe prompt = byte-identical copy of the resolved prompt + a unique
  # sentinel appended as the LAST line (#014). Same mount path, same injection
  # mechanism — but now the wire capture must contain content we planted.
  local sentinel probe_prompt
  sentinel="OC-PROBE-SENTINEL-$(date +%s)-$$-$RANDOM"
  probe_prompt="$ws/AGENTS.probe.md"
  cat "$PROMPT_FILE" > "$probe_prompt"
  printf '\n%s\n' "$sentinel" >> "$probe_prompt"
  echo "oc: probe: prompt source = $PROMPT_FILE [$PROMPT_ORIGIN]" >&2
  echo "oc: probe: sentinel = $sentinel (appended to probe copy $probe_prompt)" >&2
  echo "oc: probe: workspace = $ws (kept on failure)" >&2
  # Drive it through the standard container path: same compose service, same
  # AGENTS.md mount target — only $PWD, the config and the prompt copy are
  # swapped in for the mock.
  #
  # Mock readiness is POLLED, not slept past (#027): the old fixed `sleep 1`
  # raced node's startup — a slow cold start meant OpenCode dialed a port
  # nobody was listening on yet and the probe false-FAILed. Bounded curl loop
  # against the mock's no-capture /health route instead (100 × 0.2s = 20s
  # ceiling, then loud exit). OC_PROBE_MOCK_DELAY_MS (host env, test-only)
  # injects an artificial listen delay to exercise exactly that race.
  local mock_delay="${OC_PROBE_MOCK_DELAY_MS:-0}"
  [[ "$mock_delay" =~ ^[0-9]+$ ]] || die "OC_PROBE_MOCK_DELAY_MS must be a non-negative integer (got: $mock_delay)"
  local saved_pwd="$INVOKE_PWD" saved_cfg="${CONFIG_JSON:-}" saved_prompt="$PROMPT_FILE"
  INVOKE_PWD="$ws" CONFIG_JSON="$cfg" PROMPT_FILE="$probe_prompt" run_container \
    sh -c "node /workspace/_mock.js $mock_delay &
      i=0
      until curl -fsS -o /dev/null http://127.0.0.1:9099/health 2>/dev/null; do
        i=\$((i+1))
        if [ \"\$i\" -ge 100 ]; then
          echo 'oc probe: capture mock never came up on 127.0.0.1:9099 within 20s' >&2
          exit 9
        fi
        sleep 0.2
      done
      timeout 90 opencode run -- 'say hi' >/dev/null 2>&1
      true" || true
  INVOKE_PWD="$saved_pwd"; CONFIG_JSON="$saved_cfg"; PROMPT_FILE="$saved_prompt"
  if [[ -s "$ws/_capture.jsonl" ]] && grep -q "$sentinel" "$ws/_capture.jsonl"; then
    echo "oc: probe PASS — captured request body contains the planted prompt sentinel ($sentinel)"
    # Secondary diagnostic only — never gates (#014): a missing attribution
    # line with a delivered sentinel means upstream reworded its phrasing.
    if ! grep -q "Instructions from: $CONTAINER_PROMPT_PATH" "$ws/_capture.jsonl"; then
      echo "oc: probe note: attribution line 'Instructions from: $CONTAINER_PROMPT_PATH' absent (upstream wording change?) — sentinel proves injection regardless" >&2
    fi
    rm -rf "$ws"
    return 0
  fi
  echo "oc: probe FAIL — the planted prompt sentinel did NOT reach the captured request body." >&2
  if grep -q "Instructions from: $CONTAINER_PROMPT_PATH" "$ws/_capture.jsonl" 2>/dev/null; then
    echo "  (attribution line IS present without the sentinel — prompt content truncated/dropped in flight)" >&2
  fi
  echo "  capture: $ws/_capture.jsonl ($(wc -c < "$ws/_capture.jsonl" 2>/dev/null || echo 0) bytes)" >&2
  exit 2
}

case "$SUBCMD" in
  status) cmd_status; exit 0 ;;
  probe)  cmd_probe;  exit $? ;;
esac

# --- the daily-driver paths: bare `oc` (TUI) and `oc run` ---------------------
assert_workspace
assert_prompt
assert_config
assert_server
note_workspace

if [[ "$SUBCMD" == "run" ]]; then
  [[ $# -ge 1 ]] || die "oc run needs a prompt: oc run \"<prompt>\""
  echo "oc: tier-$TIER (:$PORT) | workspace $INVOKE_PWD | prompt [$PROMPT_ORIGIN]" >&2
  # `--` ends opencode's flag parsing (verified in-container, #014): without it
  # a dash-leading prompt parses as CLI flags (e.g. "--demo ..." silently flips
  # a real flag) instead of reaching the model as a prompt.
  rc=0; run_container opencode run -- "$@" || rc=$?
  stop_on_demand; trap - EXIT
  exit "$rc"
else
  # Interactive TUI. OpenCode's full-screen TUI needs a real terminal.
  [[ -t 0 && -t 1 ]] || die "bare \`oc\` opens the interactive TUI and needs a TTY — use \`oc run \"<prompt>\"\` for headless"
  echo "oc: tier-$TIER (:$PORT) | workspace $INVOKE_PWD | prompt [$PROMPT_ORIGIN]" >&2
  rc=0; run_container opencode || rc=$?
  stop_on_demand; trap - EXIT
  exit "$rc"
fi
