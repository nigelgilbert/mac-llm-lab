# opencode (Config B) client config. Copy to .env and edit. .env is gitignored.
#
# NOTE: unlike client/claw-code, this side has NO bridge host/port and NO API
# key — OpenCode talks straight to the second llama-server over an
# openai-compatible endpoint that needs no auth. The llama-server endpoint
# (host.docker.internal:11436/v1) lives in opencode.json, not here, because
# compose does not interpolate env into a mounted JSON file.

# Host directory bind-mounted to /workspace inside the opencode container.
# Default is a sibling `workspace/` dir; set to any absolute path you prefer.
WORKSPACE=./workspace

# OpenCode npm version to build into the image. Matches the Dockerfile default;
# pin to a concrete published version for reproducibility.
OPENCODE_VERSION=1.16.2
